# QDEX API Configuration
# Copy this file to .env and fill in your values

# Quai RPC (Orchard testnet)
QUAI_RPC_URL=https://orchard.rpc.quai.network/cyprus1

# Deployer wallet (for settlement operations)
DEPLOYER_PRIVATE_KEY=your_private_key_here

# Deployed contract addresses (Orchard Cyprus-1)
DEPLOYED_SETTLEMENT=0x...
DEPLOYED_VAULT=0x...
DEPLOYED_MARKET_REGISTRY=0x...

# Server
PORT=8787
HOST=0.0.0.0
